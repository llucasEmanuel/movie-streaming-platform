generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Movie {
  id        String   @id @default(uuid())
  title     String  
  url_movie String
  url_poster String
  synopsis  String
  genres    String[]
  duration  Int
  isDeleted Boolean @default(false)
  directors  String[]
  cast      String[]
  createdAt DateTime @default(now())
}